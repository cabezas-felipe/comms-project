{
  "meta": {
    "name": "comms-v1-editorial-system",
    "version": "0.3.0",
    "source": "04-prototype/src/index.css + tailwind.config.ts",
    "note": "Tokens use shadcn/ui CSS variable pattern. Color values are HSL triplets without the hsl() wrapper — apply as hsl(var(--token-name)) in CSS. See ds-mapping.md for old→new mapping."
  },
  "color": {
    "background": "38 30% 96%",
    "foreground": "222 25% 12%",
    "surface": "36 24% 93%",
    "surface-raised": "0 0% 100%",
    "card": "0 0% 100%",
    "card-foreground": "222 25% 12%",
    "popover": "0 0% 100%",
    "popover-foreground": "222 25% 12%",
    "primary": "222 30% 14%",
    "primary-foreground": "38 30% 96%",
    "secondary": "36 18% 88%",
    "secondary-foreground": "222 25% 18%",
    "muted": "36 18% 90%",
    "muted-foreground": "222 10% 40%",
    "accent": "36 22% 87%",
    "accent-foreground": "222 25% 14%",
    "ember": "14 80% 48%",
    "ember-foreground": "38 30% 97%",
    "ember-soft": "18 70% 94%",
    "signal-positive": "152 45% 32%",
    "signal-warning": "36 85% 42%",
    "destructive": "0 70% 42%",
    "destructive-foreground": "38 30% 97%",
    "border": "36 14% 82%",
    "rule": "222 12% 70%",
    "input": "36 14% 82%",
    "ring": "222 30% 14%"
  },
  "color-dark": {
    "background": "222 28% 8%",
    "foreground": "38 24% 92%",
    "surface": "222 25% 11%",
    "surface-raised": "222 24% 13%",
    "card": "222 24% 13%",
    "card-foreground": "38 24% 92%",
    "popover": "222 24% 13%",
    "popover-foreground": "38 24% 92%",
    "primary": "38 24% 92%",
    "primary-foreground": "222 28% 10%",
    "secondary": "222 20% 18%",
    "secondary-foreground": "38 24% 92%",
    "muted": "222 20% 16%",
    "muted-foreground": "222 10% 62%",
    "accent": "222 20% 18%",
    "accent-foreground": "38 24% 92%",
    "ember": "14 85% 58%",
    "ember-foreground": "222 28% 10%",
    "ember-soft": "14 40% 18%",
    "signal-positive": "152 45% 55%",
    "signal-warning": "36 85% 60%",
    "destructive": "0 70% 55%",
    "destructive-foreground": "38 24% 95%",
    "border": "222 18% 22%",
    "rule": "222 15% 32%",
    "input": "222 18% 22%",
    "ring": "14 85% 58%"
  },
  "font": {
    "family": {
      "display": "\"Fraunces\", Georgia, serif",
      "sans": "\"Inter\", system-ui, sans-serif",
      "mono": "\"JetBrains Mono\", ui-monospace, monospace"
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    }
  },
  "radius": {
    "base": "0.25rem",
    "note": "Tailwind borderRadius: lg = --radius, md = calc(--radius - 1px), sm = calc(--radius - 2px)"
  },
  "shadow": {
    "paper": "0 1px 0 hsl(36 14% 82%), 0 1px 2px hsl(222 25% 12% / 0.04)",
    "raised": "0 1px 0 hsl(36 14% 78%), 0 8px 24px -12px hsl(222 25% 12% / 0.12)",
    "focus": "0 0 0 3px hsl(14 80% 48% / 0.18)"
  },
  "gradient": {
    "paper": "linear-gradient(180deg, hsl(38 32% 97%) 0%, hsl(36 24% 93%) 100%)",
    "ember": "linear-gradient(135deg, hsl(14 80% 48%), hsl(22 85% 55%))"
  },
  "motion": {
    "transition-base": "180ms cubic-bezier(0.2, 0, 0, 1)",
    "easing-editorial": "cubic-bezier(0.2, 0, 0, 1)",
    "reducedMotion": {
      "note": "In CSS, @media (prefers-reduced-motion: reduce) sets all transition durations to 0ms. See tokens.css."
    }
  }
}
