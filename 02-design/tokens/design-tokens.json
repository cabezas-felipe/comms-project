{
  "meta": {
    "name": "comms-v0-design-system",
    "version": "0.2.1",
    "source": "02-design"
  },
  "color": {
    "bg": {
      "default": "#F7F8FA",
      "subtle": "#F1F3F6"
    },
    "surface": {
      "default": "#FFFFFF",
      "raised": "#FCFCFD",
      "selected": "#EDF2F7"
    },
    "border": {
      "default": "#D7DDE5",
      "strong": "#C3CBD6",
      "selected": "#B3C0D4"
    },
    "text": {
      "primary": "#454545",
      "muted": "#5F6672",
      "inverse": "#FFFFFF"
    },
    "accent": {
      "base": "#4F6887",
      "hover": "#3F5673",
      "active": "#32465F",
      "soft": "#E8EDF3"
    },
    "success": {
      "base": "#68874F",
      "soft": "#ECF2E8"
    },
    "warning": {
      "base": "#D15400",
      "soft": "#FCEEDF"
    },
    "critical": {
      "base": "#922B2E",
      "soft": "#F4E6E7"
    },
    "highlight": {
      "base": "#CEBA71",
      "soft": "#FAF6E8"
    },
    "focusRing": "#4F6887"
  },
  "font": {
    "family": {
      "heading": "\"Helvetica Neue\", \"Helvetica\", \"Arial\", sans-serif",
      "ui": "\"Helvetica Neue\", \"Helvetica\", \"Arial\", sans-serif",
      "body": "\"Calluna\", \"Georgia\", \"Times New Roman\", serif",
      "mono": "ui-monospace, SFMono-Regular, Menlo, monospace"
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600
    }
  },
  "type": {
    "size": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "md": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "xxl": "1.5rem"
    },
    "leading": {
      "tight": 1.25,
      "normal": 1.5
    }
  },
  "space": {
    "0": "0.125rem",
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "5": "1.25rem",
    "6": "1.5rem",
    "8": "2rem",
    "10": "2.5rem"
  },
  "radius": {
    "sm": "0.375rem",
    "md": "0.625rem",
    "lg": "0.875rem",
    "pill": "999px"
  },
  "motion": {
    "duration": {
      "fast": "120ms",
      "base": "180ms",
      "slow": "260ms"
    },
    "easing": {
      "standard": "cubic-bezier(0.2, 0, 0, 1)"
    },
    "reducedMotion": {
      "note": "In CSS, @media (prefers-reduced-motion: reduce) sets --motion-* durations to 0ms; see tokens.css."
    }
  }
}