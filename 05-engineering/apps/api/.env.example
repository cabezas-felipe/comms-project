# ─── Supabase (optional — leave unset to use file-based storage) ────────────────
# Free-tier project URL from https://app.supabase.com → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co

# Server-side key: bypasses RLS; keep secret, never expose to browser.
# Required for JWT verification (auth.getUser) introduced in slice 18.
# Found in: Supabase project → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=

# Client-side key: respects RLS; safe to embed in browser builds.
# Used by 04-prototype frontend (see 04-prototype/.env.example for VITE_ vars).
# Found in: Supabase project → Settings → API → anon (public)
SUPABASE_ANON_KEY=

# Postgres connection string — used ONLY by `npm run db:migrate` (the SQL runner).
# Found in: Supabase Dashboard → "Connect" button → URI tab. Replace [YOUR-PASSWORD]
# with the database password (Project Settings → Database → reset if needed).
# Never required at API runtime.
# DATABASE_URL=postgresql://postgres:<DB_PASSWORD>@db.<project-ref>.supabase.co:5432/postgres

# ─── Frontend env vars (04-prototype) — set in 04-prototype/.env ─────────────
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=

# ─── API server ─────────────────────────────────────────────────────────────────
TEMPO_API_PORT=8787

# Overrides default ./data directory (used in tests for isolation)
# TEMPO_DATA_DIR=./data

# ─── Dev QA: magic-link bypass for Supabase OTP rate limits ─────────────────
# SECURITY: NEVER enable outside a local development environment.
#
# When "true", exposes POST /api/auth/dev-magic-link which mints a one-time
# Supabase Admin API action link on demand, bypassing email delivery entirely.
# The endpoint enforces a localhost-only redirectTo allowlist as an additional
# guardrail, but the feature flag is the primary off-switch.
#
# Required env vars when enabled:
#   SUPABASE_URL=           (your project URL)
#   SUPABASE_SERVICE_ROLE_KEY=  (service-role secret — never expose to browser)
#
# The frontend calls this fallback only in Vite DEV mode and only when the
# primary OTP request is rate-limited (HTTP 429). In all other cases the
# standard Supabase signInWithOtp flow is used.
#
# Keep disabled (commented out) in shared, staging, and production environments.
# TEMPO_ENABLE_DEV_MAGIC_LINK=true
#
# ─── Production: durable rate-limit mitigations (no code changes required) ──
# If /auth/v1/otp returns 429 in production, resolve at the infrastructure
# layer — do not enable TEMPO_ENABLE_DEV_MAGIC_LINK:
#   1. Custom SMTP: Supabase → Project Settings → Auth → SMTP settings.
#      Custom providers (Resend, SendGrid, SES, Postmark) have far higher
#      per-project throughput than the default Supabase relay.
#   2. Rate-limit tuning: Supabase → Project Settings → Auth → Rate Limits.
#      Raise "Email send rate limit" (per hour) to match expected signup volume.

# ─── AI model routing ────────────────────────────────────────────────────────────
# Prefix "mock-openai-mini" / "mock-anthropic-haiku" → deterministic mocks (no key needed)
# Prefix "anthropic:<model-id>"  → live Anthropic API  (requires TEMPO_ANTHROPIC_API_KEY)
# Prefix "openai:<model-id>"     → live OpenAI-compatible API (requires TEMPO_OPENAI_API_KEY)
TEMPO_AI_SUMMARY_MODEL=mock-openai-mini
TEMPO_AI_CLASSIFIER_MODEL=mock-anthropic-haiku
# Fallback for POST /api/onboarding/extract when primary classifier fails.
# Expected production value: openai:gpt-4o (or similar OpenAI-compatible model).
TEMPO_AI_CLASSIFIER_FALLBACK_MODEL=
TEMPO_AI_SAFETY_MODEL=mock-openai-mini
TEMPO_AI_TIMEOUT_MS=1200

# ─── Dashboard clustering (Slice 1) ──────────────────────────────────────────
# Cluster model stays Sonnet for production (do not swap to Haiku without sign-off).
# Use a "mock-anthropic-*" prefix locally to run deterministic mocks (no key).
TEMPO_AI_CLUSTER_MODEL=anthropic:claude-sonnet-4-6
# Per-attempt clustering timeout (ms) — clustering-only, larger than the global
# TEMPO_AI_TIMEOUT_MS because the cluster prompt is the single largest round-trip.
# Fail-closed policy: 1 retry, then publish ZERO meta-stories (empty dashboard).
# `_meta.usedFallbackClustering=true` means "clustering failed → 0 stories" (NOT
# "degraded buckets shipped"). See README "Dashboard trust controls".
TEMPO_AI_CLUSTER_TIMEOUT_MS=60000

# ─── RSS ingestion (manifest-driven: WaPo, Reuters, AP, Bloomberg) ───────────
# Live fetch gate. See README "Source scope".
TEMPO_RSS_INGESTION=live
#
# TEMPO_RSS_ALLOWLIST is an OPTIONAL narrowing override. When set, ONLY feeds
# whose publisher matches an entry are fetched, and this env OVERRIDES the
# manifest-derived default. The default allowlist is derived from the manifest
# itself — every structurally eligible feed (active RSS + valid URL) ingests
# without listing its publisher here.
#
#   Do:    leave TEMPO_RSS_ALLOWLIST UNSET during source expansion. Fetch scope
#          then derives from the active manifest feeds, so newly-activated
#          publishers ingest automatically.
#   Don't: carry a legacy narrow allowlist into an expansion rollout — a stale
#          value silently blocks new feeds (the "Reuters-class block": a newly
#          activated publisher never fetches because it isn't in the old list).
#
# Set this ONLY to intentionally constrain fetch scope, as temporary / explicit
# narrowing. Legacy alias: TEMPO_INGESTION_ALLOWLIST.
# Note: this is a substring allowlist, NOT a wildcard — `*` blocks everything;
# unset the var (not `*`) to admit all feeds.
# Example (temporary / explicit narrowing):
# TEMPO_RSS_ALLOWLIST=washington post,reuters

# ─── Why-it-matters (implications) parallelism (Slice 6) ─────────────────────
# Bounded parallel pool size for the per-story why-it-matters writer.
# Default 4, clamped to 1..6; invalid values fall back to 4. Response story
# order stays deterministic (R1) regardless of concurrency. Latency timings
# (Slice 7) need no env knob — `_meta.timings` (incl. whyMs) is always on.
# TEMPO_AI_WHY_IT_MATTERS_CONCURRENCY=4

# ─── Geo-confidence assessor parallelism (Slice 1) ───────────────────────────
# Bounded worker-pool size for the per-item geo-assess (Haiku) calls. Running
# these sequentially starved clustering on first-run refresh; the pool caps
# in-flight calls so the geo stage stays well under the clustering timeout.
# Default 8; non-finite / <= 0 falls back to 8.
# TEMPO_AI_GEO_ASSESS_CONCURRENCY=8
#
# A1: process-wide dispatch cap (requests/minute) for the geo-assess calls.
# Concurrency bounds how many calls are in flight; this bounds how fast they're
# dispatched, so a high-concurrency first-run refresh can't trip the Anthropic
# org rate limit and bury relevant items in the hold bucket with 429s. The
# limiter is additive to (not a replacement for) the concurrency cap. A bounded
# retry/backoff on 429 (max 2 retries, 250ms exponential + jitter) absorbs the
# stray rate-limit that still slips through; all other errors keep failing safe
# to confidence=0. Default 48 (keeps a 2-RPM margin under the 50 RPM org limit);
# non-finite / <= 0 falls back to 48.
# TEMPO_AI_GEO_ASSESS_RPM_CAP=48
#
# A1.1: geo-stage wall-clock budget (ms). The geo stage splits candidates into
# two lanes — Lane 1 (protected must-see: from a selected source AND carrying a
# geo signal, i.e. an explicit geographies overlap OR a configured-geography
# lexical mention) and Lane 2 (everything else, incl. hold-bucket re-evals).
# Lane 1 ALWAYS finishes, even if it alone exceeds the budget. Lane 2 is then
# processed in concurrency-sized waves only while the budget holds; once it's
# exhausted the remainder is deferred to the hold path for re-evaluation next
# refresh (never dropped). Bounds refresh latency under heavy load without
# sacrificing must-see coverage. Default 25000; non-finite / <= 0 falls back to
# 25000.
# TEMPO_AI_GEO_STAGE_BUDGET_MS=25000

# Geo admission mode: soft (DEFAULT) = no geo admission gate — every recent
# candidate continues to recall/beat-fit/clustering (geo never defers/holds an
# item; this is what stops election headlines that omit "Colombia" from being
# dropped). hard = legacy lane-1/lane-2 gate + cold_start defer + hold + Haiku
# assessor. Unset/empty/invalid resolve to soft; only the exact value `hard`
# rolls back. Rollback command: set TEMPO_GEO_ADMISSION_MODE=hard.
# TEMPO_GEO_ADMISSION_MODE=soft

# ─── Embedding recall (Slice 1) ──────────────────────────────────────────────
# Recall mode: "hybrid_strict" (default) unions lexical keyword/topic hits with
# embedding-similar top-K items; "keyword" disables embeddings (lexical only).
TEMPO_RECALL_MODE=hybrid_strict
#
# Minimum COSINE similarity for a SEMANTIC-ONLY top-K item to join the
# hybrid_strict union. Keyword/topic hits ALWAYS bypass this floor — it gates
# only embedding-driven recall widening. Range [0,1]; 0 disables the floor.
#   • Production default is 0.35 (recall-widening; lowered from 0.40).
#   • Local calibration sweep: try 0.35–0.45 when debugging thin dashboards.
#   • Do NOT set this to 0.2 — that is the beat-fit threshold (a different stage
#     and scale; see TEMPO_BEAT_FIT_THRESHOLD below), not a cosine value.
# Observe the effect via README "Dashboard trust controls" + the ?debug=1 panel
# (diag-recall shows `semantic_rejected` and `floor=`).
TEMPO_EMBED_MIN_SIMILARITY=0.35
#
# Recall sizing knobs. embedTopK = max semantic neighbors considered for the
# union; embedMaxItems = candidate pool cap embedded per refresh. Raise only if
# you understand the latency/cost tradeoff.
TEMPO_EMBED_TOP_K=80
TEMPO_EMBED_MAX_ITEMS=250

# ─── Translation-first evidence normalization (Slice 14 + Phase 4 S0) ────────
# When enabled, non-English source items (lang != en*) get headline + first 2
# snippets translated to EN before recall, so English keyword/topic settings can
# match Spanish evidence. Originals are retained; the English text lands on
# normalizedHeadline/Body. Fail-open: a translation error/timeout passes the
# item through untranslated and never blocks a refresh. Diagnostics surface on
# `_meta.translation` and the `[pipeline.translation]` log line.
#
# Production runtime (Phase 4 S0): the server wires a real OpenAI-backed
# translateFn from TEMPO_OPENAI_API_KEY (see "API server" below) using a small/
# cheap model. The fn is no-op under TEMPO_AI_MOCK_ONLY=true or with no API key.
#
# Activation is mode-driven: `TEMPO_TRANSLATION_MODE=auto|on|off` (default auto).
# auto: run only when non-English (`lang != en*`) items are present.
# on: force translation attempts on every run.
# off: disable translation stage (fail-open pass-through).
# Legacy override: when TEMPO_TRANSLATION_ENABLED is explicitly set, it wins:
#   true/1 -> on, false/0 -> off.
# Rollback is env-only: set TEMPO_TRANSLATION_MODE=off.
# TEMPO_TRANSLATION_MODE=auto
# TEMPO_TRANSLATION_MODEL=gpt-4o-mini  # small/cheap OpenAI model for ES→EN (default)
# TEMPO_TRANSLATION_CONCURRENCY=4      # bounded worker pool; default 4, clamped 1–8
# TEMPO_TRANSLATION_TIMEOUT_MS=8000    # per-item fail-open timeout (default 8000)
#
# MULTILINGUAL E2E REQUIREMENTS (Spanish-feed runs): the pipeline runs the
# translation stage POST-GEO / PRE-RECALL, so the normalized English evidence
# (normalizedHeadline/Body) reaches BOTH clustering and the post-cluster split
# healer. Downstream readers (recall, clustering input, split-healer output)
# prefer normalized evidence and fall back to the original when absent. As a
# result, for an ES scenario the cluster + split-healer English OUTPUT depends on
# the translation stage having produced normalized evidence first. To exercise a
# real ES→EN E2E:
#   1. TEMPO_TRANSLATION_MODE=auto|on                   (turn the stage on)
#   2. TEMPO_OPENAI_API_KEY=<key>  AND  TEMPO_AI_MOCK_ONLY unset
#                                                        (a real translateFn is
#        wired only on a non-mock box with a key; otherwise the stage is a
#        fail-open no-op and ES stories stay in their original language)
# Mock-only / no-key caveat: leave the stage on for parity, but it is a no-op —
# ES output is NOT translated. Hermetic tests inject a deterministic translateFn
# instead of a live provider (see refresh-pipeline.test.mjs "ES items translated
# pre-cluster → split-healer stories are English").
#
# ─── Local E2E: Spanish feeds → English stories ──────────────────────────────
# To run a LOCAL landing → onboarding → dashboard E2E that produces ENGLISH
# stories from the Spanish feeds, set ALL of the following in your local env and
# RESTART the API (env is read at process start, not per-request):
#   TEMPO_TRANSLATION_MODE=auto           # auto-activate on non-English feeds
#   TEMPO_OPENAI_API_KEY=<your-key>       # required for a real ES→EN translateFn
#   # TEMPO_AI_MOCK_ONLY must be UNSET (commented out) — mock-only forces a no-op
#
# Verify it took effect in the API logs on the next refresh:
#   [pipeline.translation] mode=auto ... enabled=true ...  (stage is on)
#   …and when the candidate pool has Spanish items:     needed>0 translated>0
#
# IMPORTANT: if translation is OFF or unset (or on a mock-only / no-key box),
# Spanish titles/subtitles on the dashboard are EXPECTED and are NOT a clustering
# or split-healer regression — the stage simply passed the items through
# untranslated. See docs/runbook-meta-story-pipeline.md (pre-flight + E2E
# checklist) and docs/runbook-translation-activation.md.

# ─── Beat-fit precision gate (D-063) ─────────────────────────────────────────
# Precision score threshold AFTER recall — a separate stage from the cosine
# floor above, on a different scale. MVP default is recall-first 0.20; roll back
# to the precision-first 0.40 to tighten. Do NOT confuse with the embed floor.
TEMPO_BEAT_FIT_THRESHOLD=0.20

# Set to "true" to force all requests through mock providers regardless of model prefix.
# Useful for local dev, CI, or cost control without changing model config.
# TEMPO_AI_MOCK_ONLY=true

# Required when using "anthropic:<model-id>" prefix.
# TEMPO_ANTHROPIC_API_KEY takes precedence; ANTHROPIC_API_KEY is the SDK default fallback.
TEMPO_ANTHROPIC_API_KEY=
# ANTHROPIC_API_KEY=   # SDK default — only needed if TEMPO_ANTHROPIC_API_KEY is unset

# Required only when using "openai:<model-id>" prefix
# Also required for POST /api/transcribe (OpenAI Whisper voice transcription)
TEMPO_OPENAI_API_KEY=
TEMPO_OPENAI_BASE_URL=https://api.openai.com/v1

# ─── Observability / PostHog ─────────────────────────────────────────────────
# Server-side PostHog project key (found in PostHog → Project Settings → Project API Key).
# Leave empty to disable server-side analytics entirely — no crash, no-op.
# POSTHOG_API_KEY=phc-...

# Override the PostHog ingest host (EU cloud: https://eu.i.posthog.com).
# Defaults to US cloud when unset.
# POSTHOG_HOST=https://us.i.posthog.com

# ─── What-changed delta engine ───────────────────────────────────────────────
# 3-state delta semantics for `story.whatChanged` (first-seen / unchanged /
# changed).  Deterministic gate always runs; LLM stages (Haiku classify +
# Sonnet write) only run when DELTA_ENABLED is truthy AND MOCK_ONLY is unset.
# See docs/what-changed-spec.md for the full contract.
#
# Default OFF — production refreshes ship only first-seen / unchanged copy
# until an operator explicitly opts in.  Rollback is a single env flip.
# Truthy values: "true" or "1" (case-insensitive).
# TEMPO_AI_DELTA_ENABLED=false
#
# Anthropic model ids for the two stages.  Override only for SKU swaps.
# TEMPO_AI_DELTA_CLASSIFY_MODEL=anthropic:claude-haiku-4-5-20251001
# TEMPO_AI_DELTA_WRITE_MODEL=anthropic:claude-sonnet-4-6
#
# Per-call timeout shared by classify and write (ms).  On timeout the engine
# fail-closes to the unchanged copy and increments `llmFailed` counters.
# TEMPO_AI_DELTA_TIMEOUT_MS=2500
#
# When TEMPO_AI_MOCK_ONLY=true is set (see "AI model routing" above) the
# delta engine NEVER emits `changed` prose, regardless of DELTA_ENABLED.
