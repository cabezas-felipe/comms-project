{
  "name": "tempo-engineering",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web",
    "packages/contracts",
    "packages/analytics"
  ],
  "scripts": {
    "build:packages": "npm run build --workspace=@tempo/contracts --workspace=@tempo/analytics",
    "dev:api": "npm run dev --workspace=@tempo/api",
    "dev:web": "npm --prefix ../04-prototype run dev",
    "dev": "npm run build:packages && concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "build": "npm run build:packages && npm --prefix ../04-prototype run build",
    "test:api": "npm run test --workspace=@tempo/api",
    "test:packages": "npm run test --workspace=@tempo/contracts --workspace=@tempo/analytics",
    "test:prototype": "npm --prefix ../04-prototype test",
    "lint:prototype:slice": "sh -c 'cd ../04-prototype && npx eslint src/pages/Dashboard.tsx src/lib/analytics.ts'"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
