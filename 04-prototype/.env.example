# ─── Supabase (required for real magic-link auth) ────────────────────────────
# Both values are found in Supabase project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=

# ─── Supabase Auth: Redirect URLs ────────────────────────────────────────────
# The callback URL is built at runtime from window.location.origin, so it varies
# by host and port. Register every origin you develop or deploy on in:
# Supabase → Auth → URL Configuration → Redirect URLs
#
# Examples (add all that apply — Supabase does not support port wildcards):
#   http://localhost:5173/auth/callback   (Vite default port)
#   http://localhost:8080/auth/callback   (alternate dev port)
#   https://your-staging-domain/auth/callback
#
# Optional local QA fallback:
# if Supabase OTP email is throttled, frontend dev mode can request
# POST /api/auth/dev-generate-link (served by 05-engineering/apps/api)
# to mint a one-time link directly. Enable server flag:
#   TEMPO_ENABLE_DEV_MAGIC_LINK=true
